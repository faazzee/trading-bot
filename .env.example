# ── Required ──────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=8593219393:AAH65lktRFdlQzokm2OXwmidrGjmmkVYiqU

# ── Optional (all have sensible defaults) ─────────────────

# Alert threshold: notify when price moves by this % (default 3.0)
PRICE_ALERT_THRESHOLD=3.0

# How often to check prices in minutes (default 5)
PRICE_CHECK_INTERVAL=5

# How often to check news in minutes (default 30)
NEWS_CHECK_INTERVAL=30

# How often to scan for opportunities in minutes (default 60)
OPPORTUNITY_CHECK_INTERVAL=60

# SQLite database file path (default: stock_tracker.db in current dir)
DB_PATH=stock_tracker.db

# Logging level: DEBUG | INFO | WARNING | ERROR (default INFO)
LOG_LEVEL=INFO
